# ==========================================
# 1. TRADING ENGINE & SAFETY
# ==========================================
IS_LIVE_ACTIVE=False
TRADING_MODE=paper
STRATEGY=RSI_BB_FEE_AWARE_V4B
DEFAULT_SYMBOL=AAPL
LIVE_ORDER_SIZING_MODE=slot_percent
LIVE_DEFAULT_QUANTITY=100
LIVE_SLOT_ALLOCATION_PCT=0.25
LIVE_MAX_POSITION_SLOTS=4
LIVE_BUY_ALLOCATION_PCT=0.25
# Used only when LIVE_ORDER_SIZING_MODE=allocation_percent.
# For cash-account safety, prefer SettledCash. The bot also uses recent sell fills
# as a secondary unsettled-proceeds guard when execution data is available.
# Use available_funds only if margin sizing is intentional.
LIVE_BUY_CASH_SOURCE=settled_cash
# Optional comma-separated fallback chain. Leave blank to avoid buying when SettledCash is missing.
LIVE_BUY_CASH_FALLBACKS=
# Optional hard caps. Leave blank to disable.
MAX_ORDER_NOTIONAL=
MAX_ORDER_QUANTITY=
 # Web API extended-hours orders require at least one order cap.
EXT_HOURS_MAX_ORDER_NOTIONAL=
# Blank uses simulation/config/simulation_config.json. Set an explicit path only when needed.
SIM_CONFIG_PATH=

# Strategy parameters (used if applicable)
RSI_PERIOD=14
BB_LENGTH=20
BB_STD=2.2
OVERBOUGHT=70
OVERSOLD=35
TREND_SMA_PERIOD=50
BEAR_DIP_RSI=30
BB_TOLERANCE=0.003

# ==========================================
# 2. INTERACTIVE BROKERS CONNECTION (WEB API / IBEAM)
# ==========================================
IBKR_WEB_API_ENABLED=False
# Host network mode uses loopback. If you switch to Docker bridge networking,
# set this to: https://ib_web_gateway:5000/v1/api
IBKR_WEB_API_BASE_URL=https://127.0.0.1:5000/v1/api
IBKR_USER=your_username
IBKR_PW="your_password"
IBEAM_PAPER=True

# ==========================================
# 3. FALLBACK INTERACTIVE BROKERS CONNECTION (LEGACY TWS SOCKET)
# ==========================================
TWS_HOST=127.0.0.1
TWS_PORT=4001
CLIENT_ID=1

# ==========================================
# 4. MARKET DATA FEEDS
# ==========================================
MARKET_DATA_PRIMARY=yfinance
MARKET_DATA_FALLBACK_ENABLED=True
BROKER_FALLBACK_REQ_ID=91
# How often the Web API polls IBKR for new bars (TWS socket streams automatically)
BROKER_POLL_SECONDS=60
ALPHA_VANTAGE_API_KEY=your_api_key_here

# YFinance 5-minute feed settings
YF_INTERVAL=5m
YF_BACKFILL_PERIOD=5d
YF_LOOKBACK_PERIOD=2d
YF_POLL_SECONDS=20
YF_MAX_BACKFILL_BARS=500

# ==========================================
# 5. EXTENDED HOURS & SAFETY GUARDS
# ==========================================
# Enable pre-market (4:00-9:30 AM ET) and after-hours (4:00-8:00 PM ET) trading.
# When True: yfinance fetches extended-hours bars, IBKR historical data includes
# outside-RTH candles. In US *regular* session the bot uses MKT with outsideRTH off.
# In pre/after, it uses a *marketable limit* (LMT) with outsideRTH on (MKT is often
# rejected outside RTH). You may also need TWS: Global Configuration / Presets /
# Stocks / Timing: enable "Allow order to be filled outside regular trading hours".
EXTENDED_HOURS_TRADING=False
EXT_HOURS_BUY_LIMIT_PAD_PCT=0.001
EXT_HOURS_SELL_LIMIT_PAD_PCT=0.001
EXT_HOURS_LAST_PRICE_PAD_PCT=0.001
EXT_HOURS_OVERSOLD=20
EXT_HOURS_BB_STD=3.0
EXT_HOURS_BB_TOLERANCE=
# Multi-bar confirmation for extended-hours BUY/SELL. Each setup must persist
# for this many consecutive completed bars before the strategy fires. Regular
# hours always use a single-bar trigger.
EXT_HOURS_BUY_CONFIRMATION_BARS=4
EXT_HOURS_SELL_CONFIRMATION_BARS=4
# Volume filter is OFF by default: yfinance reports volume=0 for pre/after bars,
# which makes the filter unusable. Re-enable only when the broker feed is the
# active source for extended hours.
EXT_HOURS_VOLUME_FILTER_ENABLED=False
EXT_HOURS_VOLUME_LOOKBACK=50
EXT_HOURS_VOLUME_MULTIPLIER=2.0
EXT_HOURS_RESET_INDICATORS_ON_SESSION_CHANGE=True

# Trading-hours gate for live strategy processing and order submission.
# The IBKR gateway can stay authenticated outside these windows, but the bot
# will not process live bars/signals or place orders while the session is closed.
TRADING_HOURS_ENABLED=True
TRADING_HOURS_TIMEZONE=America/New_York
TRADING_SESSIONS=overnight:20:00-03:50,pre_market:04:00-09:30,regular:09:30-16:00,after_hours:16:00-20:00
# Optional global completed-bar delay for every configured session.
SESSION_MIN_COMPLETED_BARS=0
# Require this many completed 5m pre-market bars before live signal evaluation/orders.
PREMARKET_MIN_COMPLETED_BARS=3

DATA_STALE_AFTER_SECONDS=900
AUTO_PAUSE_LIVE_ON_STALE=True
LIVE_BAR_INTERVAL=5m
LIVE_STARTUP_MIN_BARS=6
BROKER_HISTORY_MIN_DAYS=2
BROKER_HISTORY_MAX_DAYS=45
LIVE_CANDLE_BUFFER_MAX=500
LIVE_STRATEGY_DF_MAX_BARS=500
LIVE_LOG_BUFFER_MAX=1000
LIVE_STATE_PATH=
LIVE_STATE_SAVE_SECONDS=2.0
LIVE_TRADES_LOOKBACK_DAYS=3
LIVE_TRADES_POLL_SECONDS=30
LIVE_ORDERS_POLL_SECONDS=5
MAX_BUYS_PER_DAY=4
MAX_ORDERS_PER_DAY=8
MIN_SECONDS_BETWEEN_ORDERS=0
DAILY_LOSS_STOP_PCT=
DASHBOARD_PORT=5050

# Telegram notifications. Put the real bot token only in local .env.
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=
TELEGRAM_TIMEOUT_SECONDS=10
TELEGRAM_NOTIFY_ORDER_SENT=False
TELEGRAM_NOTIFY_ORDER_FILLED=True
TELEGRAM_NOTIFY_TEST_BUTTON=True

# Near-signal diagnostics
NEAR_BAND_PCT=0.003
NEAR_SMI_GAP=4.0

# RSI_BB_FEE_AWARE_V4B strategy settings
FEE_PER_TRADE=2.5
FEE_AWARE_ESTIMATED_TRADE_NOTIONAL=1000
FEE_AWARE_MIN_REWARD_PCT=0.004
FEE_AWARE_REWARD_FEE_MULTIPLE=2.0
FEE_AWARE_MIN_BB_WIDTH_PCT=0.006
FEE_AWARE_REQUIRE_CONFIRMATION=True
FEE_AWARE_EXIT_RSI=55
FEE_AWARE_V3_VOLUME_MULTIPLIER=1.25
FEE_AWARE_V3_PROFIT_RSI=70
FEE_AWARE_V3_DYNAMIC_BB_MIN_STD=2.1
FEE_AWARE_V3_DYNAMIC_BB_MAX_STD=2.3
FEE_AWARE_V4_VOLUME_SPIKE_WINDOW_BARS=3
FEE_AWARE_V4_MAX_STAGNATION_BARS=24
FEE_AWARE_V4_STAGNATION_MIN_PNL_PCT=0.0
FEE_AWARE_V4_SCALE_IN_ENABLED=True
FEE_AWARE_V4_SCALE_IN_INITIAL_FRACTION=0.4
FEE_AWARE_V4_SCALE_IN_FRACTION=0.6
FEE_AWARE_V4_SCALE_IN_DROP_PCT=0.0125

# ==========================================
# 6. WEB API RECONNECTION
# ==========================================
# How long (seconds) to keep retrying a signal that failed due to broker disconnect
SIGNAL_RETRY_TTL_SECONDS=300

WEB_API_RECONNECT_ENABLED=True
WEB_API_RECONNECT_MAX_ATTEMPTS=10
WEB_API_RECONNECT_INTERVAL_SECONDS=60
WEB_API_HEALTH_CHECK_INTERVAL_SECONDS=30
WEB_API_ORDER_PREVIEW_ENABLED=False